PUBLIC_API_URL=http://localhost:3000

# Leave empty to disable Google sign-in. Must match a Web client ID
# whose authorized JavaScript origin is the frontend URL.
PUBLIC_GOOGLE_CLIENT_ID=

# Leave empty to disable Facebook sign-in. The Facebook app must list
# the frontend URL as an allowed domain.
PUBLIC_FACEBOOK_APP_ID=
PUBLIC_FACEBOOK_API_VERSION=v21.0
